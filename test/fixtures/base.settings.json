{
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run build)",
      "Read"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "DEBUG": "false",
    "API_URL": "http://localhost:3000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'pre-bash'"
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "theme": "dark"
}
