{
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(git *)",
      "Read",
      "Write"
    ]
  },
  "env": {
    "NODE_ENV": "production",
    "DEBUG": "true",
    "API_URL": "https://api.example.com"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'switch-pre-bash'"
          }
        ]
      }
    ]
  },
  "model": "claude-opus-4-7"
}
